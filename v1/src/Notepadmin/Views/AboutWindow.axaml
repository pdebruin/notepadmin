<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Notepadmin.Views.AboutWindow"
        Title="About Notepadmin"
        Width="350" Height="220"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="30" Spacing="10" HorizontalAlignment="Center">
        <TextBlock Text="Notepadmin" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Version 1.0" HorizontalAlignment="Center"/>
        <TextBlock Text="A minimal plain-text editor" HorizontalAlignment="Center" Foreground="Gray"/>
        <TextBlock Text="License: MIT" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        <TextBlock Name="SourceLink"
                   Text="Source: github.com/notepadmin"
                   HorizontalAlignment="Center"
                   Foreground="DodgerBlue"
                   Cursor="Hand"
                   TextDecorations="Underline"/>
        <Button Content="OK"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"
                Width="80"
                Click="OnOkClick"/>
    </StackPanel>
</Window>
